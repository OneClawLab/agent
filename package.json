    "README.md",
    "USAGE.md"
  ],
  "devDependencies": {
    "@types/node": "^25.4.0",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "yaml": "^2.8.0"
  }
