{
  "name": "@theclawlab/agent",
  "type": "module",
  "version": "1.0.9",
  "description": "Agent runtime and lifecycle management for TheClaw platform.",
  "bin": {
    "agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
